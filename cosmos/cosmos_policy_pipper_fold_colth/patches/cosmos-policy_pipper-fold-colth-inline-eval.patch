@@ -0,0 +1,234 @@
+"""In-training action-MAE eval callback (fastwam-style, FSDP-safe).
+
+Every `every_n` steps, evaluates action-MAE@{1,12,25} on a rank-sharded slice of the val
+episodes using the *live* training model (no checkpoint reload, no extra GPU). Mirrors
+offline_eval.py's obs construction + get_action + MAE math.
+
+FSDP FULL_SHARD correctness: a forward through the sharded net triggers a per-layer all-gather,
+which is a *collective* — every rank must run the SAME number of forwards or NCCL deadlocks.
+Episodes/windows per rank are unequal, so we pad each rank up to the global-max query count with
+dummy get_action calls (results discarded) to keep all-gathers in lockstep. The whole pass is
+wrapped in try/except: any failure only warns and restores train mode — it never crashes training.
+
+Note: this uses the *training* SDE/sampler (not the __inference_only override), so treat the
+numbers as an in-training trend; the checkpoint watcher remains the official metric.
+"""
+
+import dataclasses
+import glob
+import os
+
+import cv2
+import h5py
+import numpy as np
+import torch
+import torch.distributed as dist
+
+from megatron.core import parallel_state
+
+from cosmos_policy._src.imaginaire.callbacks.every_n import EveryN
+from cosmos_policy._src.imaginaire.utils import distributed, log
+
+
+@dataclasses.dataclass
+class _InlineEvalCfg:
+    # subset of fields read by cosmos_utils.get_action (mirrors offline_eval.EvalCfg)
+    model_family: str = "cosmos"
+    suite: str = "aloha"
+    use_third_person_image: bool = True
+    num_third_person_images: int = 1
+    use_wrist_image: bool = True
+    num_wrist_images: int = 2
+    use_proprio: bool = True
+    flip_images: bool = False
+    use_variance_scale: bool = False
+    use_jpeg_compression: bool = False
+    ar_future_prediction: bool = False
+    ar_value_prediction: bool = False
+    ar_qvalue_prediction: bool = False
+    num_denoising_steps_action: int = 10
+    num_denoising_steps_future_state: int = 1
+    num_denoising_steps_value: int = 1
+    unnormalize_actions: bool = True
+    normalize_proprio: bool = True
+    trained_with_image_aug: bool = True
+    chunk_size: int = 50
+    num_open_loop_steps: int = 50
+    deterministic: bool = True
+    seed: int = 195
+    randomize_seed: bool = False
+    dataset_stats_path: str = ""
+    t5_text_embeddings_path: str = ""
+
+
+class InlineActionEval(EveryN):
+    def __init__(
+        self,
+        every_n: int,
+        val_dir: str,
+        dataset_stats_path: str,
+        t5_text_embeddings_path: str,
+        task: str = "fold cloth",
+        horizons=(1, 12, 25),
+        stride: int = 50,
+        max_queries_per_ep: int = 4,
+        n_eps: int = 0,  # cap episodes per rank (0 = all of this rank's shard)
+        num_denoising_steps_action: int = 10,
+        chunk_size: int = 50,
+        step_size: int = 1,
+        **kwargs,
+    ):
+        super().__init__(every_n=every_n, step_size=step_size, barrier_after_run=True, **kwargs)
+        self.val_dir = val_dir
+        self.task = task
+        self.horizons = list(horizons)
+        self.stride = stride
+        self.max_queries_per_ep = max_queries_per_ep
+        self.n_eps = n_eps
+        self.cfg = _InlineEvalCfg(
+            dataset_stats_path=dataset_stats_path,
+            t5_text_embeddings_path=t5_text_embeddings_path,
+            num_denoising_steps_action=num_denoising_steps_action,
+            chunk_size=chunk_size,
+            num_open_loop_steps=chunk_size,
+        )
+        self._ready = False
+        self._eps = []          # this rank's shard: [{paths, gt, qpos, T}]
+        self._queries = []      # [(ep_idx, t_start)]
+        self._dataset_stats = None
+        self._jsonl = None
+
+    def on_train_start(self, model, iteration: int = 0) -> None:  # noqa: D401
+        try:
+            from cosmos_policy.experiments.robot.cosmos_utils import (
+                init_t5_text_embeddings_cache,
+                load_dataset_stats,
+            )
+
+            ws = parallel_state.get_data_parallel_world_size()
+            rk = parallel_state.get_data_parallel_rank()
+            all_eps = sorted(glob.glob(os.path.join(self.val_dir, "*.hdf5")))
+            my_eps = all_eps[rk::ws] if ws > 1 else all_eps
+            if self.n_eps and self.n_eps > 0:
+                my_eps = my_eps[: self.n_eps]
+            for ep in my_eps:
+                with h5py.File(ep, "r") as h:
+                    gt = np.asarray(h["action"][:], np.float32)
+                    qpos = np.asarray(h["observations/qpos"][:], np.float32)
+                    vp = {c: h[f"observations/video_paths/{c}"][()].decode()
+                          for c in ["cam_high", "cam_left_wrist", "cam_right_wrist"]}
+                self._eps.append({"paths": vp, "gt": gt, "qpos": qpos, "T": gt.shape[0]})
+            for ei, e in enumerate(self._eps):
+                starts = list(range(0, max(1, e["T"] - self.cfg.chunk_size), self.stride))[: self.max_queries_per_ep]
+                self._queries += [(ei, t) for t in starts]
+            self._dataset_stats = load_dataset_stats(self.cfg.dataset_stats_path)
+            init_t5_text_embeddings_cache(self.cfg.t5_text_embeddings_path)
+            try:
+                out_dir = os.environ.get("IMAGINAIRE_OUTPUT_ROOT", ".")
+                self._jsonl = os.path.join(out_dir, "inline_action_eval.jsonl")
+            except Exception:
+                self._jsonl = None
+            self._ready = True
+            log.info(
+                f"[inline_eval] ready: rank {rk}/{ws} got {len(self._eps)} val eps, "
+                f"{len(self._queries)} queries (stride={self.stride}, max/ep={self.max_queries_per_ep})"
+            )
+        except Exception as e:  # never block training startup
+            log.warning(f"[inline_eval] disabled (setup failed): {e}")
+            self._ready = False
+
+    def _read_frame(self, path, idx):
+        cap = cv2.VideoCapture(path)
+        cap.set(cv2.CAP_PROP_POS_FRAMES, int(idx))
+        ok, bgr = cap.read()
+        cap.release()
+        if not ok:
+            raise RuntimeError(f"frame {idx} of {path}")
+        return cv2.cvtColor(bgr, cv2.COLOR_BGR2RGB)
+
+    def _obs_for(self, ei, t):
+        e = self._eps[ei]
+        return {
+            "primary_image": self._read_frame(e["paths"]["cam_high"], t),
+            "left_wrist_image": self._read_frame(e["paths"]["cam_left_wrist"], t),
+            "right_wrist_image": self._read_frame(e["paths"]["cam_right_wrist"], t),
+            "proprio": e["qpos"][t],
+        }
+
+    def _zero_obs(self):
+        z = np.zeros((480, 640, 3), np.uint8)
+        return {"primary_image": z, "left_wrist_image": z, "right_wrist_image": z,
+                "proprio": np.zeros(14, np.float32)}
+
+    @torch.no_grad()
+    def every_n_impl(self, trainer, model, data_batch, output_batch, loss, iteration):
+        if not self._ready:
+            return
+        from cosmos_policy.experiments.robot.cosmos_utils import get_action
+
+        device = torch.cuda.current_device()
+        was_training = model.training
+        # lockstep: every rank runs the SAME number of get_action calls (global max)
+        n_local = len(self._queries)
+        n_run = torch.tensor([n_local], device=device, dtype=torch.long)
+        if dist.is_available() and dist.is_initialized():
+            dist.all_reduce(n_run, op=dist.ReduceOp.MAX)
+        n_run = int(n_run.item())
+        if n_run == 0:
+            return
+
+        # accumulators: [sum_mae@h..., cnt@h..., sum_all, cnt_all]
+        H = len(self.horizons)
+        acc = torch.zeros(2 * H + 2, device=device, dtype=torch.float64)
+        try:
+            model.eval()
+            for i in range(n_run):
+                real = i < n_local
+                if real:
+                    ei, t = self._queries[i]
+                    obs = self._obs_for(ei, t)
+                else:
+                    obs = self._zero_obs()  # dummy: keep all-gather lockstep, discard result
+                ret = get_action(self.cfg, model, self._dataset_stats, obs, self.task,
+                                 num_denoising_steps_action=self.cfg.num_denoising_steps_action,
+                                 generate_future_state_and_value_in_parallel=False)
+                if not real:
+                    continue
+                pred = np.asarray(ret["actions"], np.float32).reshape(-1, 14)[: self.cfg.chunk_size]
+                gt = self._eps[ei]["gt"][t : t + pred.shape[0]]
+                L = min(len(pred), len(gt))
+                if L < 1:
+                    continue
+                err = np.abs(pred[:L] - gt[:L])  # (L,14)
+                acc[2 * H] += float(err.mean()); acc[2 * H + 1] += 1.0
+                for hi, hh in enumerate(self.horizons):
+                    acc[hi] += float(err[: min(hh, L)].mean()); acc[H + hi] += 1.0
+        except Exception as e:
+            log.warning(f"[inline_eval] iter={iteration} FAILED: {e}")
+            if was_training:
+                model.train()
+            return
+        finally:
+            if was_training:
+                model.train()
+
+        if dist.is_available() and dist.is_initialized():
+            dist.all_reduce(acc, op=dist.ReduceOp.SUM)
+        res = {}
+        for hi, hh in enumerate(self.horizons):
+            c = acc[H + hi].item()
+            res[f"mae@{hh}"] = (acc[hi].item() / c) if c > 0 else None
+        c_all = acc[2 * H + 1].item()
+        res["mae_overall"] = (acc[2 * H].item() / c_all) if c_all > 0 else None
+        res["n_queries"] = int(c_all)
+
+        if distributed.get_rank() == 0:
+            tag = " ".join(f"mae@{hh}={res[f'mae@{hh}']:.4f}" for hh in self.horizons if res[f"mae@{hh}"] is not None)
+            log.info(f"[inline_eval] iter={iteration} {tag} mae_overall={res['mae_overall']:.4f} n={res['n_queries']}")
+            if self._jsonl:
+                try:
+                    import json
+                    with open(self._jsonl, "a") as f:
+                        f.write(json.dumps({"iter": int(iteration), **res}) + "\n")
+                except Exception:
+                    pass
