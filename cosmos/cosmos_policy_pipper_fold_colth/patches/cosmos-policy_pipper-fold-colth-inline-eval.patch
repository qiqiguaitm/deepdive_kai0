+def _local_mirror(repository: str, filename: str = "") -> str | None:
+    """Resolve a checkpoint from a local ModelScope/HF mirror dir if present.
+
+    Set COSMOS_LOCAL_MODELS=<dir> where each repo lives under <dir>/<repo-last-component>/.
+    Returns the local file path (or repo subdir) if it exists, else None. Lets us avoid
+    HF/proxy downloads entirely when the file was pre-fetched from ModelScope.
+    """
+    root = os.environ.get("COSMOS_LOCAL_MODELS", "")
+    if not root:
+        return None
+    base = os.path.join(root, repository.split("/")[-1])
+    cand = os.path.join(base, filename) if filename else base
+    if os.path.exists(cand):
+        log.info(f"checkpoint_db: using LOCAL mirror {cand} (instead of HF {repository}/{filename})")
+        return cand
+    return None
+
